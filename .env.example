# ============================================================
#  HUKUK BÜROSU SİTESİ - ÖRNEK ORTAM DEĞİŞKENLERİ
#  Bu dosyayı ".env.local" olarak kopyalayın ve değerleri doldurun.
# ============================================================

# --- Genel site ayarları ---
NEXT_PUBLIC_SITE_URL=https://www.ornekhukuk.com
NEXT_PUBLIC_WHATSAPP_NUMBER=905555555555          # Başında ülke kodu, + ve boşluk olmadan
NEXT_PUBLIC_PHONE=+90 (555) 555 55 55
NEXT_PUBLIC_EMAIL=info@ornekhukuk.com

# --- Google Maps (iletişim / harita) ---
# Google Maps "Yerleştir / Embed" iframe paylaşımından alınan tam URL veya yer adı
NEXT_PUBLIC_MAPS_EMBED_URL=

# --- Google Randevu (Calendar Appointment Schedule) ---
# Google Takvim > Randevu programı > "Rezervasyon sayfasını paylaş" linki
NEXT_PUBLIC_GOOGLE_APPOINTMENT_URL=

# ============================================================
#  GOOGLE CALENDAR API (Sunucu tarafı - randevu + Meet linki)
#  Service Account yöntemi (önerilen). Aşağıdaki 3 değeri
#  Google Cloud Console > Service Account JSON dosyasından alın.
# ============================================================
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Service Account'un takvimi yönetmesi için "domain-wide delegation"
# kullanıyorsanız, etkinlik oluşturulacak kullanıcı:
GOOGLE_IMPERSONATE_USER=

# --- E-posta bildirimi (randevu formu) - SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_TO=info@ornekhukuk.com
